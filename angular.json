{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "dd9929b5-9bec-4b0f-bc23-99607234faa6"
  },
  "newProjectRoot": "projects",
  "projects": {
    "ephoto.md": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "stylePreprocessorOptions": {
              "includePaths": ["src", "public"]
            },
            "assets": [
              "src/assets",
              {
                "glob": "**/*",
                "input": "public"
              }
            ],

            "styles": [
              {
                "input": "public/css/animate.min.css",
                "inject": true,
                "bundleName": "vendor"
              },
              {
                "input": "public/css/animated-headline.css",
                "inject": true,
                "bundleName": "vendor"
              },
              {
                "input": "public/css/flaticon.css",
                "inject": true,
                "bundleName": "vendor"
              },
              {
                "input": "public/css/fontawesome-all.min.css",
                "inject": true,
                "bundleName": "vendor"
              },
              {
                "input": "public/css/price_rangs.css",
                "inject": true,
                "bundleName": "vendor"
              },
              {
                "input": "public/css/themify-icons.css",
                "inject": true,
                "bundleName": "vendor"
              },
              "src/styles.scss",
              {
                "input": "node_modules/img-comparison-slider/dist/styles.css",
                "inject": true,
                "bundleName": "vendor"
              },
              "node_modules/ngx-owl-carousel-o/lib/styles/prebuilt-themes/owl.carousel.min.css",
              "node_modules/ngx-owl-carousel-o/lib/styles/prebuilt-themes/owl.theme.default.min.css"
            ],

            "scripts": [
              "node_modules/bootstrap/dist/js/bootstrap.min.js"
            ],
            "polyfills": ["@angular/localize/init"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "ephoto.md:build:production"
            },
            "development": {
              "buildTarget": "ephoto.md:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "proxyConfig": "./proxy.conf.json"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
